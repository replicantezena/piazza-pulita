<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Iscrizione — La Piazza Pulita</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="css/style.css">

    <style>
        body {
            background: black;
            color: #f5f5f5;
            font-family: "Cormorant Garamond", serif;
        }

        .sfondo {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-image: url('img/nebbia-iscrizione.png');
            background-size: cover;
            background-position: center;
            opacity: 0.35;
            filter: blur(4px);
            z-index: -1;
        }

        .contenitore {
            max-width: 700px;
            margin: 4rem auto;
            padding: 2rem;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(6px);
            border-radius: 14px;
        }

        h1 {
            text-align: center;
            margin-bottom: 1rem;
            text-shadow: 0 0 10px black;
        }

        label {
            display: block;
            margin-top: 1.2rem;
            font-weight: bold;
            opacity: 0.9;
        }

        input {
            width: 100%;
            padding: 0.7rem;
            margin-top: 0.3rem;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.15);
            color: white;
        }

        button {
            margin-top: 2rem;
            width: 100%;
            padding: 0.8rem;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.25);
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: rgba(255,255,255,0.4);
        }

        a.torna {
            display: block;
            margin-top: 2rem;
            text-align: center;
            color: #ddd;
            text-decoration: none;
        }

        /* Menu superiore */
        .menu-superiore {
            text-align: center;
            margin-top: 2rem;
        }

        .menu-superiore a {
            margin: 0 0.6rem;
            color: #fff;
            text-decoration: none;
            opacity: 0.8;
            transition: 0.3s;
        }

        .menu-superiore a:hover {
            opacity: 1;
            text-shadow: 0 0 8px rgba(255,255,255,0.9);
        }
    </style>
</head>

<body>

<div class="sfondo"></div>

<!-- Menu superiore -->
<div id="menu-container"></div>
<script src="js/menu.js"></script>

<div class="contenitore">

    <h1>Iscrizione</h1>

    <form action="iscrizione.php" method="POST">

        <label>Nome scelto</label>
        <input type="text" name="nome" required>

        <label>Email</label>
        <input type="email" name="email" required>

        <label>Password</label>
        <input type="password" name="password" required>

        <label>Frase personale</label>
        <input type="text" name="frase" required>

        <button type="submit">Entra nella città</button>
    </form>

    <a class="torna" href="ho-perso-me-stesso.html">Ho perso me stesso</a>
    <a class="torna" href="index.html">← Torna alla Piazza</a>

</div>

</body>
</html>
