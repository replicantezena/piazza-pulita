<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Accedi alla Città — La Piazza Pulita</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="css/style.css">

    <style>
        body {
            background: black;
            color: #f5f5f5;
            font-family: "Cormorant Garamond", serif;
        }

        .sfondo-login {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-image: url('img/nebbia-login.png');
            background-size: cover;
            background-position: center;
            opacity: 0.35;
            filter: blur(4px);
            z-index: -1;
        }

        .login-box {
            max-width: 420px;
            margin: 6rem auto;
            padding: 2rem;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(6px);
            border-radius: 14px;
            text-align: center;
        }

        .titolo-login {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 10px black;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            margin-top: 0.8rem;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.15);
            color: white;
        }

        button {
            margin-top: 2rem;
            width: 100%;
            padding: 0.8rem;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.25);
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: rgba(255,255,255,0.4);
        }

        .nota {
            margin-top: 2rem;
            font-style: italic;
            opacity: 0.85;
            line-height: 1.5;
        }

        /* Menu superiore */
        .menu-superiore {
            text-align: center;
            margin-top: 2rem;
        }

        .menu-superiore a {
            margin: 0 0.6rem;
            color: #fff;
            text-decoration: none;
            opacity: 0.8;
            transition: 0.3s;
        }

        .menu-superiore a:hover {
            opacity: 1;
            text-shadow: 0 0 8px rgba(255,255,255,0.9);
        }
    </style>
</head>

<body>

<div class="sfondo-login"></div>

<!-- Menu superiore -->
<div id="menu-container"></div>
<script src="js/menu.js"></script>

<div class="login-box">

    <h2 class="titolo-login">Identificati</h2>

    <form action="login.php" method="POST">

        <input type="email" name="email" placeholder="La tua email..." required>

        <input type="password" name="password" placeholder="La tua chiave segreta..." required>

        <button type="submit">Entra</button>

    </form>

    <p class="nota">
        La tua identità è custodita.<br>
        Nessun dato viene venduto.<br>
        Questa città non è merce.
    </p>

</div>

</body>
</html>
