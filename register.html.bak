<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Registrazione — La Piazza Pulita</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Percorso corretto -->
    <link rel="stylesheet" href="css/style.css">

    <style>
        body {
            background: black;
            color: #f5f5f5;
            font-family: "Cormorant Garamond", serif;
        }

        .sfondo-register {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-image: url('../img/nebbia-register.png'); /* percorso corretto */
            background-size: cover;
            background-position: center;
            opacity: 0.35;
            filter: blur(4px);
            z-index: -1;
        }

        /* Menu superiore */
        .menu-superiore {
            text-align: center;
            margin-top: 2rem;
            z-index: 10;
            position: relative;
        }

        .menu-superiore a {
            margin: 0 0.6rem;
            color: #fff;
            text-decoration: none;
            opacity: 0.8;
            transition: 0.3s;
        }

        .menu-superiore a:hover {
            opacity: 1;
            text-shadow: 0 0 8px rgba(255,255,255,0.9);
        }

        /* Contenitore */
        .register-box {
            max-width: 420px;
            margin: 6rem auto;
            padding: 2rem;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(6px);
            border-radius: 14px;
            text-align: center;
        }

        .titolo-register {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 10px black;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            margin-top: 0.8rem;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.15);
            color: white;
        }

        button {
            margin-top: 2rem;
            width: 100%;
            padding: 0.8rem;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.25);
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: rgba(255,255,255,0.4);
        }

        .nota {
            margin-top: 2rem;
            font-style: italic;
            opacity: 0.85;
            line-height: 1.5;
        }

        .link-login {
            margin-top: 1.5rem;
            opacity: 0.9;
        }

        .link-login a {
            color: #fff;
            text-decoration: none;
            font-weight: bold;
        }

        .link-login a:hover {
            text-shadow: 0 0 10px white;
        }
    </style>
</head>

<body class="register-body">

<div class="sfondo-register"></div>

<!-- Menu superiore -->
<div id="menu-container"></div>
<script src="js/menu.js"></script>

<div class="register-box">

    <h2 class="titolo-register">Crea la tua chiave</h2>

    <form action="login.html" method="POST">

        <input type="email" name="email" placeholder="La tua email..." required>

        <input type="password" name="password" placeholder="Crea una chiave..." required>

        <input type="password" name="password2" placeholder="Ripeti la chiave..." required>

        <button type="submit">Registrati</button>

    </form>

    <p class="nota">
        Nessun dato viene venduto.<br>
        La tua identità è custodita come in un vicolo di Genova.
    </p>

    <p class="link-login">
        Hai già una chiave? <a href="login.html">Accedi</a>
    </p>

</div>

</body>
</html>
